# Copy this file to `.env` and adjust values for your environment.
# `.env` is gitignored so your real secrets never get committed.

# local | development | production
ENVIRONMENT=local

# memory | azure_table
STORAGE_BACKEND=memory

# Comma-separated browser origins allowed to call this API (no wildcard).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ----- Only needed when STORAGE_BACKEND=azure_table -----
# In production, prefer Azure Key Vault / App Settings over a literal value here.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_TABLE_NAME=tasks
